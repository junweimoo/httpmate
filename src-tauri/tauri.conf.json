{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "httpmate",
  "version": "0.1.0",
  "identifier": "dev.httpmate.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "httpmate",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
